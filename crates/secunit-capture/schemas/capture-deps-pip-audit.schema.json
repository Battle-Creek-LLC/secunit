{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/capture-deps-pip-audit.schema.json",
  "title": "CaptureDepsPipAudit",
  "type": "object",
  "required": ["capturer", "version", "captured_at", "args", "result"],
  "additionalProperties": false,
  "properties": {
    "capturer": { "const": "deps.pip-audit" },
    "version": { "type": "string" },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "args": {
      "type": "object",
      "required": ["path"],
      "properties": { "path": { "type": "string" } }
    },
    "result": {
      "type": "object",
      "properties": {
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "vulns": { "type": "array" }
            }
          }
        }
      }
    }
  }
}
