{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/capture-envelope.schema.json",
  "title": "CaptureEnvelope",
  "description": "Canonical envelope written by every secunit capturer. Per-capturer schemas refine `capturer` and `result`.",
  "type": "object",
  "required": ["capturer", "version", "captured_at", "args", "result"],
  "additionalProperties": false,
  "properties": {
    "capturer": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "args": { "type": "object" },
    "result": {}
  }
}
