{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "secunit",
  "version": "0.1.0",
  "identifier": "work.battlecreek.secunit",
  "build": {
    "beforeDevCommand": "pnpm --dir web dev",
    "beforeBuildCommand": "pnpm --dir web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "secunit",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src-elem 'self'; style-src-attr 'unsafe-inline'; img-src 'self' asset: data: file:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
