{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "required": [
    "schema_version",
    "control_id",
    "run_id",
    "started_at",
    "completed_at",
    "agent",
    "registry_git_sha",
    "scope_layout",
    "artifacts",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "control_id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "run_id": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-run-[0-9]{3}$" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "operator": { "type": "string" },
    "agent": {
      "type": "object",
      "required": ["model", "skill", "skill_sha256", "control_sha256"],
      "properties": {
        "model": { "type": "string" },
        "skill": { "type": "string" },
        "skill_sha256": { "$ref": "#/$defs/sha256" },
        "control_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "registry_git_sha": { "$ref": "#/$defs/gitSha" },
    "scope_layout": { "type": "string", "enum": ["by-system", "flat"] },
    "resolved_scope": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "prior_run": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["run_id", "manifest_sha256"],
          "properties": {
            "run_id": { "type": "string" },
            "manifest_sha256": { "$ref": "#/$defs/sha256" }
          },
          "additionalProperties": false
        }
      ]
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "by_system": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "artifacts"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["complete", "skipped", "failed"] },
          "summary": { "type": "object", "additionalProperties": true },
          "artifacts": {
            "type": "array",
            "items": { "$ref": "#/$defs/artifact" }
          }
        },
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "failed"]
    },
    "failure_reason": { "type": "string" },
    "draft_risks": { "type": "array" },
    "draft_issues": { "type": "array" },
    "external_links": { "type": "array" },
    "period_id": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
    "artifact": {
      "type": "object",
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
