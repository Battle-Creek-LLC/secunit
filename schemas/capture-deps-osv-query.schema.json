{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/capture-deps-osv-query.schema.json",
  "title": "CaptureDepsOsvQuery",
  "type": "object",
  "required": ["capturer", "version", "captured_at", "args", "result"],
  "additionalProperties": false,
  "properties": {
    "capturer": { "const": "deps.osv-query" },
    "version": { "type": "string" },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "args": {
      "type": "object",
      "required": ["ecosystem", "package", "version"],
      "properties": {
        "ecosystem": { "type": "string" },
        "package": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "result": {
      "type": "object",
      "properties": {
        "vulns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": { "id": { "type": "string" } }
          }
        }
      }
    }
  }
}
