{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/capture-github-branch-protection.schema.json",
  "title": "CaptureGithubBranchProtection",
  "type": "object",
  "required": ["capturer", "version", "captured_at", "args", "result"],
  "additionalProperties": false,
  "properties": {
    "capturer": { "const": "github.branch-protection" },
    "version": { "type": "string" },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "args": {
      "type": "object",
      "required": ["repo", "branch"],
      "properties": {
        "repo": { "type": "string" },
        "branch": { "type": "string" }
      }
    },
    "result": { "type": "object" }
  }
}
