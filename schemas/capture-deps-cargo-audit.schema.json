{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Battle-Creek-LLC/secunit/schemas/capture-deps-cargo-audit.schema.json",
  "title": "CaptureDepsCargoAudit",
  "type": "object",
  "required": ["capturer", "version", "captured_at", "args", "result"],
  "additionalProperties": false,
  "properties": {
    "capturer": { "const": "deps.cargo-audit" },
    "version": { "type": "string" },
    "captured_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "args": {
      "type": "object",
      "required": ["lockfile"],
      "properties": {
        "lockfile": { "type": "string" },
        "db_path": { "type": ["string", "null"] }
      }
    },
    "result": {
      "type": "object",
      "properties": {
        "lockfile": { "type": "object" },
        "vulnerabilities": {
          "type": "object",
          "required": ["count", "found", "list"],
          "properties": {
            "found": { "type": "boolean" },
            "count": { "type": "integer" },
            "list": { "type": "array" }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "items"],
            "properties": {
              "kind": { "type": "string" },
              "items": { "type": "array" }
            }
          }
        }
      }
    }
  }
}
